# External raw datasets / symlinks
external_data/*
!external_data/.gitkeep

# Local raw datasets
data/*
!data/.gitkeep
!data/carla/
data/carla/*
!data/carla/.gitkeep
!data/carla/simulation_45/
!data/carla/simulation_50/
!data/carla/simulation_51/
!data/carla/simulation_52/
!data/carla/simulation_53/
!data/carla/[0-9]*.[0-9]*/
!data/smartroom/
data/smartroom/*
!data/smartroom/.gitkeep

# Large media files
*.mp4
*.avi
*.mov
!data/carla/simulation_45/simulation_45.mp4
!data/carla/simulation_50/simulation_50.mp4
!data/carla/simulation_51/simulation_51.mp4
!data/carla/simulation_52/simulation_52.mp4
!data/carla/[0-9]*.[0-9]*/*.mp4

# export_to_repo.py's <scenario>.<variant> labels (5.1, 4.2, etc.) are
# written by --repo_path to the REPO ROOT, not under data/carla/ - that's
# what the data/carla/[0-9]*.[0-9]*/ rules above originally assumed, so
# they never matched anything and the blanket *.mp4 rule was silently
# blocking every root-level export's video. The already-tracked root-level
# exports (2.1, 4.1-4.4, 5.1-5.7, 6.44-6.49) were git mv'd into data/carla/
# on 2026-07-22, where those data/carla/[0-9]*.[0-9]*/ rules now actually
# apply. This root-anchored rule stays in place because export_to_repo.py
# itself still writes NEW exports to the repo root (unchanged so far) -
# without it, a fresh root-level export's mp4 would be silently blocked
# again. Some untracked root-level exports (6.1-6.43) still exist and rely
# on this rule. Retire this rule only after export_to_repo.py is changed
# to write directly under data/carla/.
!/[0-9]*.[0-9]*/*.mp4

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.pycache/
