# External raw datasets / symlinks
external_data/*
!external_data/.gitkeep

# Local raw datasets
data/*
!data/.gitkeep
!data/carla/
data/carla/*
!data/carla/.gitkeep
!data/carla/simulation_45/
!data/carla/simulation_50/
!data/carla/simulation_51/
!data/carla/simulation_52/
!data/carla/simulation_53/
!data/carla/[0-9]*.[0-9]*/
!data/smartroom/
data/smartroom/*
!data/smartroom/.gitkeep

# Large media files
*.mp4
*.avi
*.mov
!data/carla/simulation_45/simulation_45.mp4
!data/carla/simulation_50/simulation_50.mp4
!data/carla/simulation_51/simulation_51.mp4
!data/carla/simulation_52/simulation_52.mp4
!data/carla/[0-9]*.[0-9]*/*.mp4

# export_to_repo.py's <scenario>.<variant> labels (5.1, 4.2, etc.) actually
# land at the REPO ROOT (confirmed via `find . -maxdepth 2 -iname "5.1"` ->
# ./5.1), not under data/carla/ like the rule above assumed - that earlier
# rule never matched anything for this reason, and the blanket *.mp4 rule
# above was still silently blocking every root-level export's video.
!/[0-9]*.[0-9]*/*.mp4

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.pycache/
